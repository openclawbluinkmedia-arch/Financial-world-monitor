# ─── Deployment Mode ───────────────────────────────────────────
# dev   = NVIDIA NIM + OpenRouter fallback
# customer = self-hosted vLLM
DEPLOYMENT_MODE=dev

# ─── Reasoning LLM — NVIDIA NIM (dev mode primary) ────────────
NVIDIA_API_KEY=nvapi-...
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL_SLUG=qwen/qwen3.5-397b-a17b

# ─── Reasoning LLM — OpenRouter (dev mode fallback) ───────────
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL_SLUG=qwen/qwen3.7-plus

# ─── Reasoning LLM — Self-hosted vLLM (customer mode) ─────────
VLLM_BASE_URL=http://vllm:8000/v1
VLLM_MODEL_SLUG=qwen/qwen3.5-397b-a17b

# ─── Embeddings (always local CPU via sentence-transformers) ──
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024

# ─── Postgres ─────────────────────────────────────────────────
POSTGRES_USER=fios
POSTGRES_PASSWORD=fios_secret
POSTGRES_DB=fios
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://fios:fios_secret@postgres:5432/fios

# ─── Redis ────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ─── Auth ─────────────────────────────────────────────────────
SECRET_KEY=<generate a 64-char random key>
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── CORS — comma-separated list of allowed origins ──────────
# For Vercel: https://your-project.vercel.app
CORS_ORIGINS=http://localhost:3000,https://your-project.vercel.app

# ─── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO
STRUCTURED_LOG=True
