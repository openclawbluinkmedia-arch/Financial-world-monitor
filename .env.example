# ─── Deployment Mode ───────────────────────────────────────────
# dev   = NVIDIA NIM (primary) + OpenRouter (fallback)
# customer = self-hosted vLLM; no external API calls
DEPLOYMENT_MODE=dev

# ─── Reasoning LLM — NVIDIA NIM (dev mode primary) ────────────
NVIDIA_API_KEY=nvapi-...
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL_SLUG=qwen/qwen3.5-397b-a17b

# ─── Reasoning LLM — OpenRouter (dev mode fallback) ───────────
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL_SLUG=qwen/qwen3.7-plus

# ─── Reasoning LLM — Self-hosted vLLM (customer mode) ─────────
VLLM_BASE_URL=http://vllm:8000/v1
VLLM_MODEL_SLUG=qwen/qwen3.5-397b-a17b

# ─── Embeddings (remote via NIM; no local models) ─────────────
# Leave blank to reuse NVIDIA_API_KEY/BASE_URL
EMBEDDING_API_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=nvidia/nv-embedqa-e5-v5
EMBEDDING_DIM=1024

# ─── Postgres ─────────────────────────────────────────────────
# Option A — individual components (preferred, handles special chars safely)
DB_HOST=localhost
DB_PORT=5432
DB_USER=fios
DB_PASSWORD=fios_secret
DB_NAME=fios

# Option B — single URL  (used only when DB_HOST is empty)
# DATABASE_URL=postgresql+asyncpg://fios:fios_secret@localhost:5432/fios

# SSL — auto-set to "require" when host is not localhost
# DATABASE_SSL=require

# ─── Redis ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# ─── Auth ─────────────────────────────────────────────────────
SECRET_KEY=replace-with-a-strong-random-key-64-bytes
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ─── Ingest API guard (for GitHub Actions cron) ───────────────
INGEST_TOKEN=

# ─── Scheduler ────────────────────────────────────────────────
ENABLE_SCHEDULER=true

# ─── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO
STRUCTURED_LOG=True
